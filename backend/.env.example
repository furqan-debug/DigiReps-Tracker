# DigiReps Backend — Environment Variables
# Copy this file to .env and fill in your Supabase credentials

# Supabase project URL (from Supabase Dashboard → Settings → API)
SUPABASE_URL=https://lgmggbnaoyoapxqsfgzv.supabase.co

# Supabase service role key (NOT the anon key — this bypasses RLS)
# Found in Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase anon/public key — used for Auth.signInWithPassword verification
# Found in Supabase Dashboard → Settings → API → anon public
SUPABASE_ANON_KEY=your-anon-key

# Port for the ingestion API (default: 3001)
PORT=3001

# URL of the admin portal — used as the redirect target in invite emails
# (Supabase will append /accept-invite to this URL)
# Change to your production domain when deploying
ADMIN_PORTAL_URL=http://localhost:5174